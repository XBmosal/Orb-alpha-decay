<Application x:Class="FlowTerminal.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- Dark-first palette. Mirrors FlowTerminal.Charting.ChartPalette defaults. -->
        <Color x:Key="BackgroundColor">#FF0E0F12</Color>
        <Color x:Key="PanelColor">#FF15171C</Color>
        <Color x:Key="GridColor">#FF2A2E36</Color>
        <Color x:Key="TextColor">#FFE6E8EC</Color>
        <Color x:Key="MutedTextColor">#FF8B909A</Color>
        <Color x:Key="BullishColor">#FF22C55E</Color>
        <Color x:Key="BearishColor">#FFC4A7FF</Color>
        <Color x:Key="WarningColor">#FFF59E0B</Color>

        <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
        <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
        <SolidColorBrush x:Key="GridBrush" Color="{StaticResource GridColor}" />
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
        <SolidColorBrush x:Key="BullishBrush" Color="{StaticResource BullishColor}" />
        <SolidColorBrush x:Key="BearishBrush" Color="{StaticResource BearishColor}" />
        <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
    </Application.Resources>
</Application>
