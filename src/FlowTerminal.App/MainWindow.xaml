<Window x:Class="FlowTerminal.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FlowTerminal.App.Controls"
        Title="Flow Terminal — Read-Only Order Flow (NQ / ES)"
        Height="800" Width="1280" MinWidth="940" MinHeight="560"
        Background="{StaticResource WorkspaceBrush}"
        TextOptions.TextFormattingMode="Ideal"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- 0 Command bar -->
            <RowDefinition Height="Auto" />   <!-- 1 Toolbar -->
            <RowDefinition Height="Auto" />   <!-- 2 Workspace tabs -->
            <RowDefinition Height="*" MinHeight="320" /> <!-- 3 Main workspace -->
            <RowDefinition Height="Auto" />   <!-- 4 Footer -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════ WORKSPACE TABS ════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource WorkspaceBrush}" Padding="8,5,8,0">
            <StackPanel x:Name="WorkspaceTabs" Orientation="Horizontal" />
        </Border>

        <!-- ════════════════════════════ COMMAND BAR ════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource SurfacePrimaryBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Margin="14,0">

                <!-- Identity + instrument -->
                <Ellipse DockPanel.Dock="Left" Width="9" Height="9" Margin="0,0,9,0"
                         VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" />
                <TextBlock DockPanel.Dock="Left" Text="FLOW TERMINAL" Style="{StaticResource AppTitleStyle}"
                           VerticalAlignment="Center" Margin="0,0,14,0" />
                <Border DockPanel.Dock="Left" Style="{StaticResource VDividerStyle}" Height="22" />
                <!-- Instrument selector -->
                <ToggleButton x:Name="InstrumentButton" DockPanel.Dock="Left" Style="{StaticResource ToolbarToggleStyle}"
                              VerticalAlignment="Center" Margin="12,0,6,0" Padding="9,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="InstrumentTitleText" Style="{StaticResource InstrumentTitleStyle}" Text="—" />
                        <TextBlock Text="▾" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </ToggleButton>
                <Popup x:Name="InstrumentPopup" PlacementTarget="{Binding ElementName=InstrumentButton}" Placement="Bottom"
                       StaysOpen="False" AllowsTransparency="True"
                       IsOpen="{Binding IsChecked, ElementName=InstrumentButton, Mode=TwoWay}">
                    <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderStrongBrush}"
                            BorderThickness="1" CornerRadius="8" Margin="6" MinWidth="240" SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.5" Color="#000000" />
                        </Border.Effect>
                        <StackPanel x:Name="InstrumentMenu" Margin="6" />
                    </Border>
                </Popup>

                <!-- Contract selector -->
                <ToggleButton x:Name="ContractButton" DockPanel.Dock="Left" Style="{StaticResource ToolbarToggleStyle}"
                              VerticalAlignment="Center" Margin="0,0,16,0" Padding="9,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ContractText" Style="{StaticResource BadgeTextStyle}" FontWeight="SemiBold"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Text="—" />
                        <TextBlock Text="▾" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </ToggleButton>
                <Popup x:Name="ContractPopup" PlacementTarget="{Binding ElementName=ContractButton}" Placement="Bottom"
                       StaysOpen="False" AllowsTransparency="True"
                       IsOpen="{Binding IsChecked, ElementName=ContractButton, Mode=TwoWay}">
                    <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderStrongBrush}"
                            BorderThickness="1" CornerRadius="8" Margin="6" MinWidth="200" SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.5" Color="#000000" />
                        </Border.Effect>
                        <StackPanel x:Name="ContractMenu" Margin="6" />
                    </Border>
                </Popup>

                <!-- Last price + change -->
                <TextBlock DockPanel.Dock="Left" x:Name="LastPriceText" Style="{StaticResource NumericLargeStyle}"
                           Text="—" Margin="0,0,10,0" />
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock x:Name="ChangeText" Style="{StaticResource MetricValueStyle}" FontSize="12"
                               Foreground="{StaticResource BullishBrush}" Text="—" />
                    <TextBlock x:Name="ChangePctText" Style="{StaticResource MetricValueStyle}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Text="" />
                </StackPanel>
                <Border DockPanel.Dock="Left" Style="{StaticResource VDividerStyle}" Height="22" />

                <!-- OHLC + Volume -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                    <TextBlock Text="O" Style="{StaticResource OverlineStyle}" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="OpenText" Style="{StaticResource CellStyle}" Text="—" Margin="0,0,12,0" />
                    <TextBlock Text="H" Style="{StaticResource OverlineStyle}" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="HighText" Style="{StaticResource CellStyle}" Foreground="{StaticResource BullishBrush}" Text="—" Margin="0,0,12,0" />
                    <TextBlock Text="L" Style="{StaticResource OverlineStyle}" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="LowText" Style="{StaticResource CellStyle}" Foreground="{StaticResource BearishBrush}" Text="—" Margin="0,0,12,0" />
                    <TextBlock Text="C" Style="{StaticResource OverlineStyle}" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="CloseText" Style="{StaticResource CellStyle}" Text="—" Margin="0,0,12,0" />
                    <TextBlock Text="V" Style="{StaticResource OverlineStyle}" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="VolumeText" Style="{StaticResource CellStyle}" Foreground="{StaticResource TextSecondaryBrush}" Text="—" />
                </StackPanel>

                <!-- Right cluster: session + status badges + settings -->
                <Button DockPanel.Dock="Right" Style="{StaticResource IconButtonStyle}" Content="⚙"
                        ToolTip="Settings" Margin="6,0,0,0" />
                <Border DockPanel.Dock="Right" Style="{StaticResource SimulatedBadgeStyle}" Margin="6,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0" Fill="{StaticResource WarningBrush}" />
                        <TextBlock x:Name="SimulatedBanner" Style="{StaticResource BadgeTextStyle}"
                                   Foreground="{StaticResource WarningBrush}" Text="SIMULATED DATA" />
                    </StackPanel>
                </Border>
                <Border DockPanel.Dock="Right" Style="{StaticResource OutlineBadgeStyle}" Margin="6,0,0,0">
                    <TextBlock x:Name="ReadOnlyBanner" Style="{StaticResource BadgeTextStyle}"
                               Foreground="{StaticResource ReadOnlyBrush}" Text="READ ONLY" />
                </Border>
                <TextBlock DockPanel.Dock="Right" x:Name="SessionText" Style="{StaticResource TextMutedStyle}"
                           VerticalAlignment="Center" Margin="0,0,6,0" Text="" />
            </DockPanel>
        </Border>

        <!-- ════════════════════════════ TOOLBAR ════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceSecondaryBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Margin="12,5">

                <!-- Segmented timeframe control -->
                <Border DockPanel.Dock="Left" Background="{StaticResource SurfacePrimaryBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="2" VerticalAlignment="Center">
                    <StackPanel x:Name="TimeframeBar" Orientation="Horizontal" />
                </Border>

                <Border DockPanel.Dock="Left" Style="{StaticResource VDividerStyle}" Height="20" />

                <!-- Indicators -->
                <ToggleButton x:Name="IndicatorsButton" DockPanel.Dock="Left"
                              Style="{StaticResource ToolbarToggleStyle}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ƒ" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center" />
                        <TextBlock Text="Indicators" VerticalAlignment="Center" />
                        <TextBlock Text=" ▾" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>

                <Popup x:Name="IndicatorsPopup" PlacementTarget="{Binding ElementName=IndicatorsButton}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                       IsOpen="{Binding IsChecked, ElementName=IndicatorsButton, Mode=TwoWay}">
                    <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderStrongBrush}"
                            BorderThickness="1" CornerRadius="8" Margin="6" Width="350" SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.55" Color="#000000" />
                        </Border.Effect>
                        <DockPanel Margin="6">
                            <TextBlock DockPanel.Dock="Top" Text="INDICATORS" Style="{StaticResource OverlineStyle}"
                                       Margin="10,8,0,8" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="540">
                                <StackPanel x:Name="IndicatorsPanel" Margin="2,0,2,6" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Popup>

                <Border DockPanel.Dock="Left" Style="{StaticResource VDividerStyle}" Height="20" />

                <!-- Chart type -->
                <Border DockPanel.Dock="Left" Background="{StaticResource SurfacePrimaryBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="2" VerticalAlignment="Center">
                    <StackPanel x:Name="ChartTypeBar" Orientation="Horizontal" />
                </Border>

                <Border DockPanel.Dock="Left" Style="{StaticResource VDividerStyle}" Height="20" />

                <!-- Footprint cell mode (active in the footprint study) -->
                <Button x:Name="FootprintModeButton" DockPanel.Dock="Left" Style="{StaticResource IconButtonStyle}"
                        Width="Auto" Padding="11,0" Content="FP: Bid×Ask"
                        ToolTip="Footprint cell mode — click to cycle (enable the Footprint study to see it)" />

                <Border DockPanel.Dock="Left" Style="{StaticResource VDividerStyle}" Height="20" />

                <!-- Templates -->
                <ToggleButton x:Name="TemplatesButton" DockPanel.Dock="Left" Style="{StaticResource ToolbarToggleStyle}"
                              VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Templates" VerticalAlignment="Center" />
                        <TextBlock Text=" ▾" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <Popup x:Name="TemplatesPopup" PlacementTarget="{Binding ElementName=TemplatesButton}" Placement="Bottom"
                       StaysOpen="False" AllowsTransparency="True"
                       IsOpen="{Binding IsChecked, ElementName=TemplatesButton, Mode=TwoWay}">
                    <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderStrongBrush}"
                            BorderThickness="1" CornerRadius="8" Margin="6" Width="310" SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.5" Color="#000000" />
                        </Border.Effect>
                        <DockPanel Margin="6">
                            <TextBlock DockPanel.Dock="Top" Text="TEMPLATES" Style="{StaticResource OverlineStyle}" Margin="10,8,0,6" />
                            <StackPanel DockPanel.Dock="Bottom" Margin="6,8,6,2">
                                <TextBlock Text="SAVE CURRENT LAYOUT" Style="{StaticResource OverlineStyle}" Margin="4,0,0,4" />
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" x:Name="TemplateSaveButton" Style="{StaticResource IconButtonStyle}"
                                            Width="Auto" Padding="14,0" Content="Save" Margin="6,0,0,0"
                                            Foreground="{StaticResource AccentBrush}" />
                                    <TextBox x:Name="TemplateNameBox" Background="{StaticResource SurfacePrimaryBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}"
                                             BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                             FontFamily="{StaticResource UiFontFamily}" FontSize="12" Padding="6,3"
                                             VerticalContentAlignment="Center" />
                                </DockPanel>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
                                <StackPanel x:Name="TemplatesListPanel" Margin="2,0,2,4" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Popup>

                <Border DockPanel.Dock="Left" Style="{StaticResource VDividerStyle}" Height="20" />

                <!-- Undo / redo / add indicator -->
                <Button DockPanel.Dock="Left" x:Name="UndoButton" Style="{StaticResource IconButtonStyle}"
                        Content="↶" ToolTip="Undo drawing" />
                <Button DockPanel.Dock="Left" x:Name="RedoButton" Style="{StaticResource IconButtonStyle}"
                        Content="↷" ToolTip="Redo drawing" />
                <Button DockPanel.Dock="Left" x:Name="AddIndicatorButton" Style="{StaticResource IconButtonStyle}"
                        Content="＋" ToolTip="Add indicator" />

                <!-- Connection status (far right) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="ConnectionDot" Width="7" Height="7" Margin="0,0,7,0"
                             VerticalAlignment="Center" Fill="{StaticResource BullishBrush}" />
                    <TextBlock Text="CONNECTED" Style="{StaticResource OverlineStyle}"
                               Foreground="{StaticResource BullishBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <Border DockPanel.Dock="Right" Style="{StaticResource VDividerStyle}" Height="20" />

                <!-- Playback transport -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PLAYBACK" Style="{StaticResource OverlineStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button x:Name="RestartButton" Style="{StaticResource IconButtonStyle}" Content="↺" ToolTip="Restart session" />
                    <ToggleButton x:Name="PlayPauseButton" Style="{StaticResource IconToggleStyle}" Content="❚❚" ToolTip="Pause / resume" />
                    <Button x:Name="SpeedButton" Style="{StaticResource IconButtonStyle}" Width="Auto" Padding="9,0"
                            Content="1×" ToolTip="Playback speed" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ════════════════════════════ CHART WORKSPACE ════════════════════════════ -->
        <Grid x:Name="ChartWorkspace" Grid.Row="3" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="360" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: chart (top) + lower analytics (CVD | heatmap) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="200" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="248" MinHeight="140" />
                </Grid.RowDefinitions>

                <!-- Chart panel -->
                <Border Grid.Row="0" Style="{StaticResource PanelSurfaceStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderBarStyle}">
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" x:Name="ChartHeaderText"
                                           Style="{StaticResource PanelTitleStyle}"
                                           Foreground="{StaticResource TextPrimaryBrush}" Text="Chart" />
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource TextMutedStyle}"
                                           VerticalAlignment="Center"
                                           Text="drag to pan · drag price/time axes to zoom" />
                            </DockPanel>
                        </Border>
                        <Border DockPanel.Dock="Left" Background="{StaticResource SurfaceSecondaryBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0" Width="38">
                            <StackPanel x:Name="DrawingToolbar" Orientation="Vertical" Margin="5,6" />
                        </Border>
                        <Border Background="{StaticResource AppBackgroundBrush}" CornerRadius="0,0,6,0" ClipToBounds="True">
                            <controls:SkiaChartHost x:Name="Chart" />
                        </Border>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" />

                <!-- Lower analytics: CVD (heatmap now lives in its own workspace tab) -->
                <Border Grid.Row="2" Style="{StaticResource PanelSurfaceStyle}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderBarStyle}">
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" Text="CVD" Style="{StaticResource PanelTitleStyle}" />
                                    <Border DockPanel.Dock="Right" Background="{StaticResource SurfacePrimaryBrush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                            CornerRadius="5" Padding="2" VerticalAlignment="Center">
                                        <StackPanel x:Name="CvdModeBar" Orientation="Horizontal" />
                                    </Border>
                                </DockPanel>
                            </Border>

                            <Grid>
                                <!-- Number-only view -->
                                <StackPanel x:Name="CvdNumberView" Margin="14,12" VerticalAlignment="Center" Visibility="Collapsed">
                                    <TextBlock Text="SESSION DELTA" Style="{StaticResource OverlineStyle}" Margin="0,0,0,2" />
                                    <TextBlock x:Name="CvdText" Style="{StaticResource NumericMediumStyle}" Text="0" />
                                    <TextBlock Style="{StaticResource TextMutedStyle}" Margin="0,6,0,0"
                                               Text="Net aggressive buy − sell volume" />
                                </StackPanel>

                                <!-- Sparkline / candles view -->
                                <DockPanel x:Name="CvdChartView">
                                    <Grid DockPanel.Dock="Top" Margin="12,8,12,2">
                                        <TextBlock Text="SESSION DELTA" Style="{StaticResource OverlineStyle}" VerticalAlignment="Center" />
                                        <TextBlock x:Name="CvdValueSmall" Style="{StaticResource MetricValueStyle}" FontSize="14"
                                                   HorizontalAlignment="Right" Text="0" />
                                    </Grid>
                                    <Border Background="{StaticResource AppBackgroundBrush}" CornerRadius="0,0,6,6" ClipToBounds="True">
                                        <controls:CvdHost x:Name="CvdChart" />
                                    </Border>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <!-- RIGHT RAIL: Order Book (top) + Time & Sales (bottom) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="200" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="0.85*" MinHeight="150" />
                </Grid.RowDefinitions>

                <!-- Order Book -->
                <Border Grid.Row="0" Style="{StaticResource PanelSurfaceStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderBarStyle}">
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="Order Book" Style="{StaticResource PanelTitleStyle}" />
                                <TextBlock DockPanel.Dock="Left" Text="MBP" Style="{StaticResource OverlineStyle}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                <Border DockPanel.Dock="Right" x:Name="BookStateChip" Style="{StaticResource OutlineBadgeStyle}"
                                        Padding="7,2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="BookStateDot" Width="6" Height="6" Margin="0,0,5,0"
                                                 VerticalAlignment="Center" Fill="{StaticResource BullishBrush}" />
                                        <TextBlock x:Name="BookStateText" Style="{StaticResource BadgeTextStyle}"
                                                   FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="—" />
                                    </StackPanel>
                                </Border>
                            </DockPanel>
                        </Border>
                        <!-- Column header -->
                        <Border DockPanel.Dock="Top" Background="{StaticResource SurfacePrimaryBrush}" Padding="10,5"
                                BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="74" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="PRICE" Style="{StaticResource ColumnHeaderStyle}" Margin="10,0,0,0" />
                                <TextBlock Grid.Column="1" Text="BID" Style="{StaticResource ColumnHeaderStyle}"
                                           Foreground="{StaticResource BullishBrush}" TextAlignment="Right" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="2" Text="ASK" Style="{StaticResource ColumnHeaderStyle}"
                                           Foreground="{StaticResource BearishBrush}" TextAlignment="Right" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="3" Text="Σ BID" Style="{StaticResource ColumnHeaderStyle}" TextAlignment="Right" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="4" Text="Σ ASK" Style="{StaticResource ColumnHeaderStyle}" TextAlignment="Right" Margin="0,0,10,0" />
                            </Grid>
                        </Border>

                        <!-- Spread footer -->
                        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceSecondaryBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0" Padding="12,7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="BID" Style="{StaticResource OverlineStyle}"
                                               Foreground="{StaticResource BullishBrush}" VerticalAlignment="Center" Margin="0,0,7,0" />
                                    <TextBlock x:Name="BidPriceText" Style="{StaticResource MetricValueStyle}" FontSize="13"
                                               Foreground="{StaticResource BullishBrush}" Text="—" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="{StaticResource SurfacePrimaryBrush}" CornerRadius="4"
                                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" Padding="8,1" Margin="14,0">
                                    <TextBlock x:Name="SpreadText" Style="{StaticResource CellStyle}"
                                               Foreground="{StaticResource TextSecondaryBrush}" Text="—" />
                                </Border>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="ASK" Style="{StaticResource OverlineStyle}"
                                               Foreground="{StaticResource BearishBrush}" VerticalAlignment="Center" Margin="0,0,7,0" />
                                    <TextBlock x:Name="AskPriceText" Style="{StaticResource MetricValueStyle}" FontSize="13"
                                               Foreground="{StaticResource BearishBrush}" Text="—" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="DomList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding RowBackground}" Padding="0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="74" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Price}" Style="{StaticResource CellStyle}"
                                                           FontWeight="SemiBold" Foreground="{Binding PriceBrush}" Margin="10,0,0,0" />
                                                <!-- Bid size + depth bar (grows toward the ask side) -->
                                                <Grid Grid.Column="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding BidRest}" />
                                                        <ColumnDefinition Width="{Binding BidFill}" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="1" Background="{StaticResource BullishSoftBrush}" CornerRadius="2" Margin="0,1" />
                                                    <TextBlock Grid.ColumnSpan="2" Text="{Binding Bid}" Style="{StaticResource CellStyle}"
                                                               Foreground="{Binding BidBrush}" TextAlignment="Right" Margin="0,0,8,0" />
                                                </Grid>
                                                <!-- Ask size + depth bar -->
                                                <Grid Grid.Column="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding AskFill}" />
                                                        <ColumnDefinition Width="{Binding AskRest}" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="{StaticResource BearishSoftBrush}" CornerRadius="2" Margin="0,1" />
                                                    <TextBlock Grid.ColumnSpan="2" Text="{Binding Ask}" Style="{StaticResource CellStyle}"
                                                               Foreground="{Binding AskBrush}" TextAlignment="Right" Margin="0,0,8,0" />
                                                </Grid>
                                                <TextBlock Grid.Column="3" Text="{Binding CumBid}" Style="{StaticResource CellStyle}"
                                                           Foreground="{StaticResource TextMutedBrush}" TextAlignment="Right" Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="4" Text="{Binding CumAsk}" Style="{StaticResource CellStyle}"
                                                           Foreground="{StaticResource TextMutedBrush}" TextAlignment="Right" Margin="0,0,10,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" />

                <!-- Time & Sales -->
                <Border Grid.Row="2" Style="{StaticResource PanelSurfaceStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderBarStyle}">
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="Time &amp; Sales" Style="{StaticResource PanelTitleStyle}" />
                                <Button DockPanel.Dock="Right" x:Name="MinSizeButton" Style="{StaticResource IconButtonStyle}"
                                        Width="Auto" Padding="9,0" Margin="6,0,0,0" FontSize="11" Content="≥ 0"
                                        ToolTip="Minimum trade size filter (click to cycle)" />
                                <Border DockPanel.Dock="Right" Background="{StaticResource SurfacePrimaryBrush}"
                                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                        CornerRadius="5" Padding="2" VerticalAlignment="Center">
                                    <StackPanel x:Name="SideFilterBar" Orientation="Horizontal" />
                                </Border>
                            </DockPanel>
                        </Border>
                        <Border DockPanel.Dock="Top" Background="{StaticResource SurfacePrimaryBrush}" Padding="10,5"
                                BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="34" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="TIME" Style="{StaticResource ColumnHeaderStyle}" />
                                <TextBlock Grid.Column="1" Text="PRICE" Style="{StaticResource ColumnHeaderStyle}" TextAlignment="Right" />
                                <TextBlock Grid.Column="2" Text="SIZE" Style="{StaticResource ColumnHeaderStyle}" TextAlignment="Right" />
                                <TextBlock Grid.Column="3" Text="SIDE" Style="{StaticResource ColumnHeaderStyle}" TextAlignment="Center" />
                            </Grid>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="TapeList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding RowBackground}" Padding="10,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="86" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="56" />
                                                    <ColumnDefinition Width="34" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Time}" Style="{StaticResource CellStyle}"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Price}" Style="{StaticResource CellStyle}"
                                                           TextAlignment="Right" Foreground="{Binding SideBrush}" />
                                                <TextBlock Grid.Column="2" Text="{Binding Size}" Style="{StaticResource CellStyle}"
                                                           TextAlignment="Right" />
                                                <TextBlock Grid.Column="3" Text="{Binding Side}" Style="{StaticResource CellStyle}"
                                                           TextAlignment="Center" FontWeight="Bold" Foreground="{Binding SideBrush}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ════════════════════════════ HEATMAP WORKSPACE ════════════════════════════ -->
        <Border x:Name="HeatmapWorkspace" Grid.Row="3" Margin="8" Visibility="Collapsed"
                Style="{StaticResource PanelSurfaceStyle}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderBarStyle}">
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="Liquidity Heatmap" Style="{StaticResource PanelTitleStyle}"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock DockPanel.Dock="Left" Text="BOOKMAP" Style="{StaticResource OverlineStyle}"
                                   Margin="8,0,0,0" VerticalAlignment="Center" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center" Fill="{StaticResource BullishBrush}" />
                            <TextBlock Text="BID LIQUIDITY · BUYS" Style="{StaticResource OverlineStyle}" Margin="0,0,12,0" />
                            <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center" Fill="{StaticResource BearishBrush}" />
                            <TextBlock Text="ASK LIQUIDITY · SELLS" Style="{StaticResource OverlineStyle}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Contrast filter -->
                <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceSecondaryBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0" Padding="12,7">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left" Text="CONTRAST FILTER" Style="{StaticResource OverlineStyle}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <Border DockPanel.Dock="Right" Style="{StaticResource OutlineBadgeStyle}" Padding="8,2" Margin="12,0,0,0">
                            <TextBlock x:Name="ContrastValueText" Style="{StaticResource MetricValueStyle}" FontSize="12"
                                       Foreground="{StaticResource AccentBrush}" Text="≥ 0" />
                        </Border>
                        <TextBlock DockPanel.Dock="Right" Text="hide passive orders below this size"
                                   Style="{StaticResource TextMutedStyle}" VerticalAlignment="Center" Margin="12,0,0,0" />
                        <Slider x:Name="ContrastSlider" Style="{StaticResource ThemeSliderStyle}"
                                Minimum="0" Maximum="500" Value="0" SmallChange="5" LargeChange="25"
                                VerticalAlignment="Center" Margin="0,0,8,0" />
                    </DockPanel>
                </Border>

                <Border Background="{StaticResource AppBackgroundBrush}" CornerRadius="0,0,6,6" ClipToBounds="True">
                    <controls:HeatmapHost x:Name="Heatmap" />
                </Border>
            </DockPanel>
        </Border>

        <!-- ════════════════════════════ FOOTER ════════════════════════════ -->
        <Border Grid.Row="4" Background="{StaticResource SurfacePrimaryBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False" Margin="14,6">

                <!-- Diagnostics metric chips -->
                <StackPanel x:Name="DiagnosticsChips" DockPanel.Dock="Left" Orientation="Horizontal">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="EVENTS/SEC" Style="{StaticResource OverlineStyle}" />
                        <TextBlock x:Name="MetricEventsRate" Style="{StaticResource MetricValueStyle}" Text="0" />
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="QUEUE DEPTH" Style="{StaticResource OverlineStyle}" />
                        <TextBlock x:Name="MetricQueue" Style="{StaticResource MetricValueStyle}" Text="0" />
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="DROPPED" Style="{StaticResource OverlineStyle}" />
                        <TextBlock x:Name="MetricDropped" Style="{StaticResource MetricValueStyle}" Text="0" />
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="SEQ GAPS" Style="{StaticResource OverlineStyle}" />
                        <TextBlock x:Name="MetricGaps" Style="{StaticResource MetricValueStyle}" Text="0" />
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="SIGNALS" Style="{StaticResource OverlineStyle}" />
                        <TextBlock x:Name="MetricSignals" Style="{StaticResource MetricValueStyle}" Text="0" />
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="LAST SIGNAL" Style="{StaticResource OverlineStyle}" />
                        <TextBlock x:Name="MetricLastSignal" Style="{StaticResource MetricValueStyle}" FontWeight="Normal"
                                   Foreground="{StaticResource TextSecondaryBrush}" MaxWidth="180"
                                   TextTrimming="CharacterEllipsis" Text="—" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="BOOK STATE" Style="{StaticResource OverlineStyle}" />
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="MetricBookDot" Width="6" Height="6" Margin="0,0,5,0"
                                     VerticalAlignment="Center" Fill="{StaticResource BullishBrush}" />
                            <TextBlock x:Name="MetricBookState" Style="{StaticResource MetricValueStyle}" FontSize="12" Text="—" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Connection + version -->
                <TextBlock DockPanel.Dock="Right" Text="v0.37.0" Style="{StaticResource TextMutedStyle}"
                           VerticalAlignment="Center" Margin="14,0,0,0" />
                <Border DockPanel.Dock="Right" Style="{StaticResource VDividerStyle}" Height="18" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Margin="0,0,8,0" VerticalAlignment="Center" Fill="{StaticResource BullishBrush}" />
                    <StackPanel>
                        <TextBlock x:Name="RithmicStatusText" Style="{StaticResource MetricValueStyle}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Text="Rithmic (Mock)" />
                        <TextBlock x:Name="ConnectionRegionText" Style="{StaticResource OverlineStyle}" Text="US EAST · NEW YORK" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
