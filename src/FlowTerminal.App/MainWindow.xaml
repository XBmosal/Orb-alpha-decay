<Window x:Class="FlowTerminal.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FlowTerminal.App.Controls"
        Title="Flow Terminal — Read-Only Order Flow (NQ / ES)"
        Height="800" Width="1280" MinWidth="940" MinHeight="560"
        Background="{StaticResource WorkspaceBrush}"
        TextOptions.TextFormattingMode="Ideal"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- 0 Command bar -->
            <RowDefinition Height="Auto" />   <!-- 1 Toolbar -->
            <RowDefinition Height="*" MinHeight="320" /> <!-- 2 Main workspace -->
            <RowDefinition Height="Auto" />   <!-- 3 Footer -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════ COMMAND BAR ════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource SurfacePrimaryBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Margin="14,0">

                <!-- Identity + instrument -->
                <Ellipse DockPanel.Dock="Left" Width="9" Height="9" Margin="0,0,9,0"
                         VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" />
                <TextBlock DockPanel.Dock="Left" Text="FLOW TERMINAL" Style="{StaticResource AppTitleStyle}"
                           VerticalAlignment="Center" Margin="0,0,14,0" />
                <Border DockPanel.Dock="Left" Style="{StaticResource VDividerStyle}" Height="22" />
                <TextBlock DockPanel.Dock="Left" x:Name="InstrumentTitleText" Style="{StaticResource InstrumentTitleStyle}"
                           Margin="14,0,10,0" Text="—" />
                <Border DockPanel.Dock="Left" Style="{StaticResource OutlineBadgeStyle}" Padding="7,2" Margin="0,0,16,0">
                    <TextBlock x:Name="ContractText" Style="{StaticResource BadgeTextStyle}" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Text="—" />
                </Border>

                <!-- Last price + change -->
                <TextBlock DockPanel.Dock="Left" x:Name="LastPriceText" Style="{StaticResource NumericLargeStyle}"
                           Text="—" Margin="0,0,10,0" />
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock x:Name="ChangeText" Style="{StaticResource MetricValueStyle}" FontSize="12"
                               Foreground="{StaticResource BullishBrush}" Text="—" />
                    <TextBlock x:Name="ChangePctText" Style="{StaticResource MetricValueStyle}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Text="" />
                </StackPanel>
                <Border DockPanel.Dock="Left" Style="{StaticResource VDividerStyle}" Height="22" />

                <!-- OHLC + Volume -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                    <TextBlock Text="O" Style="{StaticResource OverlineStyle}" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="OpenText" Style="{StaticResource CellStyle}" Text="—" Margin="0,0,12,0" />
                    <TextBlock Text="H" Style="{StaticResource OverlineStyle}" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="HighText" Style="{StaticResource CellStyle}" Foreground="{StaticResource BullishBrush}" Text="—" Margin="0,0,12,0" />
                    <TextBlock Text="L" Style="{StaticResource OverlineStyle}" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="LowText" Style="{StaticResource CellStyle}" Foreground="{StaticResource BearishBrush}" Text="—" Margin="0,0,12,0" />
                    <TextBlock Text="C" Style="{StaticResource OverlineStyle}" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="CloseText" Style="{StaticResource CellStyle}" Text="—" Margin="0,0,12,0" />
                    <TextBlock Text="V" Style="{StaticResource OverlineStyle}" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="VolumeText" Style="{StaticResource CellStyle}" Foreground="{StaticResource TextSecondaryBrush}" Text="—" />
                </StackPanel>

                <!-- Right cluster: session + status badges + settings -->
                <Button DockPanel.Dock="Right" Style="{StaticResource IconButtonStyle}" Content="⚙"
                        ToolTip="Settings" Margin="6,0,0,0" />
                <Border DockPanel.Dock="Right" Style="{StaticResource SimulatedBadgeStyle}" Margin="6,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0" Fill="{StaticResource WarningBrush}" />
                        <TextBlock x:Name="SimulatedBanner" Style="{StaticResource BadgeTextStyle}"
                                   Foreground="{StaticResource WarningBrush}" Text="SIMULATED DATA" />
                    </StackPanel>
                </Border>
                <Border DockPanel.Dock="Right" Style="{StaticResource OutlineBadgeStyle}" Margin="6,0,0,0">
                    <TextBlock x:Name="ReadOnlyBanner" Style="{StaticResource BadgeTextStyle}"
                               Foreground="{StaticResource ReadOnlyBrush}" Text="READ ONLY" />
                </Border>
                <TextBlock DockPanel.Dock="Right" x:Name="SessionText" Style="{StaticResource TextMutedStyle}"
                           VerticalAlignment="Center" Margin="0,0,6,0" Text="" />
            </DockPanel>
        </Border>

        <!-- ════════════════════════════ TOOLBAR ════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceSecondaryBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Margin="12,5">

                <!-- Segmented timeframe control -->
                <Border DockPanel.Dock="Left" Background="{StaticResource SurfacePrimaryBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="2" VerticalAlignment="Center">
                    <StackPanel x:Name="TimeframeBar" Orientation="Horizontal" />
                </Border>

                <Border DockPanel.Dock="Left" Style="{StaticResource VDividerStyle}" Height="20" />

                <!-- Indicators -->
                <ToggleButton x:Name="IndicatorsButton" DockPanel.Dock="Left"
                              Style="{StaticResource ToolbarToggleStyle}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ƒ" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center" />
                        <TextBlock Text="Indicators" VerticalAlignment="Center" />
                        <TextBlock Text=" ▾" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>

                <Popup x:Name="IndicatorsPopup" PlacementTarget="{Binding ElementName=IndicatorsButton}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                       IsOpen="{Binding IsChecked, ElementName=IndicatorsButton, Mode=TwoWay}">
                    <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderStrongBrush}"
                            BorderThickness="1" CornerRadius="8" Margin="6" Width="350" SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.55" Color="#000000" />
                        </Border.Effect>
                        <DockPanel Margin="6">
                            <TextBlock DockPanel.Dock="Top" Text="INDICATORS" Style="{StaticResource OverlineStyle}"
                                       Margin="10,8,0,8" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="540">
                                <StackPanel x:Name="IndicatorsPanel" Margin="2,0,2,6" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Popup>

                <Border DockPanel.Dock="Left" Style="{StaticResource VDividerStyle}" Height="20" />

                <!-- Chart type -->
                <Border DockPanel.Dock="Left" Background="{StaticResource SurfacePrimaryBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="2" VerticalAlignment="Center">
                    <StackPanel x:Name="ChartTypeBar" Orientation="Horizontal" />
                </Border>

                <!-- Connection status (right) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="ConnectionDot" Width="7" Height="7" Margin="0,0,7,0"
                             VerticalAlignment="Center" Fill="{StaticResource BullishBrush}" />
                    <TextBlock Text="CONNECTED" Style="{StaticResource OverlineStyle}"
                               Foreground="{StaticResource BullishBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ════════════════════════════ MAIN WORKSPACE ════════════════════════════ -->
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="360" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: chart (top) + lower analytics (CVD | heatmap) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="200" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="248" MinHeight="140" />
                </Grid.RowDefinitions>

                <!-- Chart panel -->
                <Border Grid.Row="0" Style="{StaticResource PanelSurfaceStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderBarStyle}">
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" x:Name="ChartHeaderText"
                                           Style="{StaticResource PanelTitleStyle}"
                                           Foreground="{StaticResource TextPrimaryBrush}" Text="Chart" />
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource TextMutedStyle}"
                                           VerticalAlignment="Center"
                                           Text="drag to pan · drag price/time axes to zoom" />
                            </DockPanel>
                        </Border>
                        <Border Background="{StaticResource AppBackgroundBrush}" CornerRadius="0,0,6,6" ClipToBounds="True">
                            <controls:SkiaChartHost x:Name="Chart" />
                        </Border>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" />

                <!-- Lower analytics -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" MinWidth="180" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" MinWidth="220" />
                    </Grid.ColumnDefinitions>

                    <!-- CVD -->
                    <Border Grid.Column="0" Style="{StaticResource PanelSurfaceStyle}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderBarStyle}">
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" Text="Cumulative Volume Delta"
                                               Style="{StaticResource PanelTitleStyle}" />
                                    <Border DockPanel.Dock="Right" x:Name="BookStateChip" Style="{StaticResource OutlineBadgeStyle}"
                                            Padding="7,2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="BookStateDot" Width="6" Height="6" Margin="0,0,5,0"
                                                     VerticalAlignment="Center" Fill="{StaticResource BullishBrush}" />
                                            <TextBlock x:Name="BookStateText" Style="{StaticResource BadgeTextStyle}"
                                                       FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="—" />
                                        </StackPanel>
                                    </Border>
                                </DockPanel>
                            </Border>
                            <StackPanel Margin="14,12" VerticalAlignment="Center">
                                <TextBlock Text="SESSION DELTA" Style="{StaticResource OverlineStyle}" Margin="0,0,0,2" />
                                <TextBlock x:Name="CvdText" Style="{StaticResource NumericMediumStyle}" Text="0" />
                                <TextBlock x:Name="CvdHintText" Style="{StaticResource TextMutedStyle}" Margin="0,6,0,0"
                                           Text="Net aggressive buy − sell volume" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                    <!-- Liquidity heatmap -->
                    <Border Grid.Column="2" Style="{StaticResource PanelSurfaceStyle}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderBarStyle}">
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" Text="Liquidity Heatmap"
                                               Style="{StaticResource PanelTitleStyle}" />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center" Fill="{StaticResource BidBrush}" />
                                        <TextBlock Text="BID" Style="{StaticResource OverlineStyle}" Margin="0,0,10,0" />
                                        <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center" Fill="{StaticResource AskBrush}" />
                                        <TextBlock Text="ASK" Style="{StaticResource OverlineStyle}" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <Border Background="{StaticResource AppBackgroundBrush}" CornerRadius="0,0,6,6" ClipToBounds="True">
                                <controls:HeatmapHost x:Name="Heatmap" />
                            </Border>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <!-- RIGHT RAIL: Order Book (top) + Time & Sales (bottom) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="200" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="0.85*" MinHeight="150" />
                </Grid.RowDefinitions>

                <!-- Order Book -->
                <Border Grid.Row="0" Style="{StaticResource PanelSurfaceStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderBarStyle}">
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="Order Book" Style="{StaticResource PanelTitleStyle}" />
                                <TextBlock DockPanel.Dock="Left" Text="MBP" Style="{StaticResource OverlineStyle}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                <TextBlock DockPanel.Dock="Right" Text="READ-ONLY" Style="{StaticResource OverlineStyle}"
                                           Foreground="{StaticResource ReadOnlyBrush}" VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                        <!-- Column header -->
                        <Border DockPanel.Dock="Top" Background="{StaticResource SurfacePrimaryBrush}" Padding="10,5"
                                BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="BID" Style="{StaticResource ColumnHeaderStyle}"
                                           Foreground="{StaticResource BidBrush}" />
                                <TextBlock Grid.Column="1" Text="PRICE" Style="{StaticResource ColumnHeaderStyle}" TextAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="ASK" Style="{StaticResource ColumnHeaderStyle}"
                                           Foreground="{StaticResource AskBrush}" TextAlignment="Right" />
                            </Grid>
                        </Border>
                        <controls:DomHost x:Name="Dom" />
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" />

                <!-- Time & Sales -->
                <Border Grid.Row="2" Style="{StaticResource PanelSurfaceStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderBarStyle}">
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="Time &amp; Sales" Style="{StaticResource PanelTitleStyle}" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center" Fill="{StaticResource BullishBrush}" />
                                    <TextBlock Text="BUY" Style="{StaticResource OverlineStyle}" Margin="0,0,10,0" />
                                    <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center" Fill="{StaticResource BearishBrush}" />
                                    <TextBlock Text="SELL" Style="{StaticResource OverlineStyle}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <Border DockPanel.Dock="Top" Background="{StaticResource SurfacePrimaryBrush}" Padding="10,5"
                                BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="34" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="TIME" Style="{StaticResource ColumnHeaderStyle}" />
                                <TextBlock Grid.Column="1" Text="PRICE" Style="{StaticResource ColumnHeaderStyle}" TextAlignment="Right" />
                                <TextBlock Grid.Column="2" Text="SIZE" Style="{StaticResource ColumnHeaderStyle}" TextAlignment="Right" />
                                <TextBlock Grid.Column="3" Text="SIDE" Style="{StaticResource ColumnHeaderStyle}" TextAlignment="Center" />
                            </Grid>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="TapeList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding RowBackground}" Padding="10,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="86" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="56" />
                                                    <ColumnDefinition Width="34" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Time}" Style="{StaticResource CellStyle}"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Price}" Style="{StaticResource CellStyle}"
                                                           TextAlignment="Right" Foreground="{Binding SideBrush}" />
                                                <TextBlock Grid.Column="2" Text="{Binding Size}" Style="{StaticResource CellStyle}"
                                                           TextAlignment="Right" />
                                                <TextBlock Grid.Column="3" Text="{Binding Side}" Style="{StaticResource CellStyle}"
                                                           TextAlignment="Center" FontWeight="Bold" Foreground="{Binding SideBrush}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ════════════════════════════ FOOTER ════════════════════════════ -->
        <Border Grid.Row="3" Background="{StaticResource SurfacePrimaryBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False" Margin="14,7">
                <TextBlock DockPanel.Dock="Left" Text="DIAGNOSTICS" Style="{StaticResource OverlineStyle}"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock DockPanel.Dock="Left" x:Name="DiagnosticsText" Style="{StaticResource DiagnosticsStyle}"
                           VerticalAlignment="Center" Text="" />

                <TextBlock DockPanel.Dock="Right" Text="v0.24.0" Style="{StaticResource TextMutedStyle}"
                           VerticalAlignment="Center" Margin="12,0,0,0" />
                <Border DockPanel.Dock="Right" Style="{StaticResource VDividerStyle}" Height="16" />
                <TextBlock DockPanel.Dock="Right" x:Name="RithmicStatusText" Style="{StaticResource TextMutedStyle}"
                           VerticalAlignment="Center" Text="" />
                <Ellipse DockPanel.Dock="Right" Width="7" Height="7" Margin="0,0,7,0" VerticalAlignment="Center"
                         Fill="{StaticResource WarningBrush}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
