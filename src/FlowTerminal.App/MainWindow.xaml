<Window x:Class="FlowTerminal.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FlowTerminal.App.Controls"
        Title="Flow Terminal — Read-Only Order Flow (NQ / ES)"
        Height="900" Width="1500"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Subtle, grabbable splitter. Drag near a panel border to resize. -->
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="{StaticResource GridBrush}" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="ShowsPreview" Value="True" />
        </Style>

        <!-- Flat pill-style toggle used for the timeframe selector and the Indicators
             button. Highlights on hover and when checked (the active timeframe). -->
        <Style x:Key="ChipToggleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="11,4" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource GridBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource GridBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />               <!-- 0 Toolbar: indicators + title + OHLC + banners -->
            <RowDefinition Height="Auto" />               <!-- 1 Timeframe bar -->
            <RowDefinition Height="*" MinHeight="160" />   <!-- 2 Main chart + DOM -->
            <RowDefinition Height="6" />                   <!-- 3 row splitter -->
            <RowDefinition Height="240" MinHeight="120" /> <!-- 4 CVD / Heatmap / T&S -->
            <RowDefinition Height="6" />                   <!-- 5 row splitter -->
            <RowDefinition Height="180" MinHeight="80" />  <!-- 6 Diagnostics -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="8,5">
            <DockPanel LastChildFill="False">

                <!-- Indicators menu button (top-left) -->
                <ToggleButton x:Name="IndicatorsButton" DockPanel.Dock="Left"
                              Style="{StaticResource ChipToggleStyle}" Margin="0,0,12,0" Padding="12,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Indicators" />
                        <TextBlock Text="  ▾" />
                    </StackPanel>
                </ToggleButton>

                <Popup x:Name="IndicatorsPopup" PlacementTarget="{Binding ElementName=IndicatorsButton}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                       IsOpen="{Binding IsChecked, ElementName=IndicatorsButton, Mode=TwoWay}">
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource GridBrush}"
                            BorderThickness="1" CornerRadius="8" Margin="6" Width="340"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.5" Color="#000000" />
                        </Border.Effect>
                        <DockPanel Margin="6">
                            <TextBlock DockPanel.Dock="Top" Text="Indicators" FontWeight="SemiBold"
                                       FontSize="13" Margin="8,6,0,6" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="520">
                                <StackPanel x:Name="IndicatorsPanel" Margin="2,0,2,6" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Popup>

                <!-- Instrument title -->
                <TextBlock x:Name="InstrumentTitleText" DockPanel.Dock="Left"
                           VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold"
                           Margin="0,0,18,0" Text="—" />

                <!-- Live OHLC readout for the latest bar -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="O" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,3,0" />
                    <TextBlock x:Name="OpenText" Text="—" Margin="0,0,12,0" />
                    <TextBlock Text="H" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,3,0" />
                    <TextBlock x:Name="HighText" Text="—" Foreground="{StaticResource BullishBrush}" Margin="0,0,12,0" />
                    <TextBlock Text="L" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,3,0" />
                    <TextBlock x:Name="LowText" Text="—" Foreground="{StaticResource BearishBrush}" Margin="0,0,12,0" />
                    <TextBlock Text="C" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,3,0" />
                    <TextBlock x:Name="CloseText" Text="—" Margin="0,0,12,0" />
                    <TextBlock x:Name="ChangeText" Text="" FontWeight="SemiBold" />
                </StackPanel>

                <!-- Status banners (right) -->
                <Border DockPanel.Dock="Right" Background="{StaticResource WarningBrush}"
                        CornerRadius="4" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="SimulatedBanner" Foreground="#FF15171C" FontWeight="Bold" />
                </Border>
                <Border DockPanel.Dock="Right" BorderBrush="{StaticResource MutedTextBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                    <TextBlock x:Name="ReadOnlyBanner" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" />
                </Border>
            </DockPanel>
        </Border>

        <!-- ── Timeframe bar ───────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="6,3" Margin="0,6,0,0">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="Timeframe" Foreground="{StaticResource MutedTextBrush}"
                           VerticalAlignment="Center" Margin="4,0,10,0" />
                <StackPanel x:Name="TimeframeBar" DockPanel.Dock="Left" Orientation="Horizontal" />

                <TextBlock DockPanel.Dock="Right" x:Name="ContractText" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}" Margin="10,0,4,0" />
                <TextBlock DockPanel.Dock="Right" x:Name="SessionText" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}" Margin="10,0,0,0" />
            </DockPanel>
        </Border>

        <!-- Main area: chart (left) + resizable splitter + read-only DOM (right) -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="260" MinWidth="120" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="6" ClipToBounds="True">
                <controls:SkiaChartHost x:Name="Chart" />
            </Border>
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="6" ClipToBounds="True">
                <controls:DomHost x:Name="Dom" />
            </Border>
        </Grid>

        <GridSplitter Grid.Row="3" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" />

        <!-- CVD + Liquidity Heatmap + Time and Sales (all resizable) -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="120" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="160" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="320" MinWidth="140" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="12">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Cumulative Volume Delta" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock x:Name="CvdText" Text="0" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock x:Name="BookStateText" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="6" ClipToBounds="True">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Liquidity Heatmap (bid green / ask purple)"
                               Foreground="{StaticResource MutedTextBrush}" Margin="8,6,0,4" />
                    <controls:HeatmapHost x:Name="Heatmap" />
                </DockPanel>
            </Border>
            <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <Border Grid.Column="4" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Time and Sales (read-only)"
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4" />
                    <TextBlock x:Name="TapeText" FontFamily="Consolas" FontSize="12" />
                </DockPanel>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="5" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" />

        <!-- Diagnostics -->
        <Border Grid.Row="6" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Diagnostics" Foreground="{StaticResource MutedTextBrush}"
                           FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock x:Name="DiagnosticsText" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" />
                <TextBlock x:Name="RithmicStatusText" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0"
                           DockPanel.Dock="Bottom" VerticalAlignment="Bottom" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
