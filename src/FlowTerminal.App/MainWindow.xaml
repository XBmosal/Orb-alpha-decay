<Window x:Class="FlowTerminal.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FlowTerminal.App.Controls"
        Title="Flow Terminal — Read-Only Order Flow (NQ / ES)"
        Height="900" Width="1500"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Subtle, grabbable splitter. Drag near a panel border to resize. -->
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="{StaticResource GridBrush}" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="ShowsPreview" Value="True" />
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />               <!-- 0 Top status bar -->
            <RowDefinition Height="*" MinHeight="160" />   <!-- 1 Main chart + DOM -->
            <RowDefinition Height="6" />                   <!-- 2 row splitter -->
            <RowDefinition Height="240" MinHeight="120" /> <!-- 3 CVD / Heatmap / T&S -->
            <RowDefinition Height="6" />                   <!-- 4 row splitter -->
            <RowDefinition Height="210" MinHeight="80" />  <!-- 5 Bottom tabs -->
        </Grid.RowDefinitions>

        <!-- Top status bar -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="10,6">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Flow Terminal" FontSize="15" FontWeight="SemiBold" Margin="0,0,16,0" />
                <TextBlock Text="Instrument:" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,4,0" />
                <TextBlock x:Name="InstrumentText" Margin="0,0,16,0" />
                <TextBlock Text="Contract:" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,4,0" />
                <TextBlock x:Name="ContractText" Margin="0,0,16,0" />
                <TextBlock Text="Session:" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,4,0" />
                <TextBlock x:Name="SessionText" Margin="0,0,16,0" />
                <Border DockPanel.Dock="Right" Background="{StaticResource WarningBrush}"
                        CornerRadius="4" Padding="8,2" Margin="8,0,0,0">
                    <TextBlock x:Name="SimulatedBanner" Foreground="#FF15171C" FontWeight="Bold" />
                </Border>
                <Border DockPanel.Dock="Right" BorderBrush="{StaticResource MutedTextBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="8,2">
                    <TextBlock x:Name="ReadOnlyBanner" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" />
                </Border>
            </DockPanel>
        </Border>

        <!-- Main area: chart (left) + resizable splitter + read-only DOM (right) -->
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="260" MinWidth="120" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="6" ClipToBounds="True">
                <controls:SkiaChartHost x:Name="Chart" />
            </Border>
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="6" ClipToBounds="True">
                <controls:DomHost x:Name="Dom" />
            </Border>
        </Grid>

        <GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" />

        <!-- CVD + Liquidity Heatmap + Time and Sales (all resizable) -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="120" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="160" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="320" MinWidth="140" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="12">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Cumulative Volume Delta" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock x:Name="CvdText" Text="0" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock x:Name="BookStateText" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="6" ClipToBounds="True">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Liquidity Heatmap (bid green / ask purple)"
                               Foreground="{StaticResource MutedTextBrush}" Margin="8,6,0,4" />
                    <controls:HeatmapHost x:Name="Heatmap" />
                </DockPanel>
            </Border>
            <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <Border Grid.Column="4" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Time and Sales (read-only)"
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4" />
                    <TextBlock x:Name="TapeText" FontFamily="Consolas" FontSize="12" />
                </DockPanel>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="4" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" />

        <!-- Bottom tabs: Studies | Diagnostics -->
        <Border Grid.Row="5" Background="{StaticResource PanelBrush}" CornerRadius="6">
            <TabControl Background="Transparent" BorderThickness="0">
                <TabItem Header="Studies">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                        <StackPanel x:Name="StudiesPanel" />
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Diagnostics">
                    <StackPanel Margin="10">
                        <TextBlock x:Name="DiagnosticsText" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" />
                        <TextBlock x:Name="RithmicStatusText" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
