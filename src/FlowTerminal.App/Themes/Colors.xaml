<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
      Flow Terminal design system — color foundation.
      A premium dark terminal built from several closely-related dark surfaces
      rather than one flat black. Accent colors are reserved for live data,
      market direction, selection, and status. Green/purple market identity is
      mandatory: bullish green #22C55E, bearish light-purple #C4A7FF.
    -->

    <!-- ── Structural surfaces (darkest → most elevated) ─────────────────── -->
    <Color x:Key="AppBackgroundColor">#FF0A0C11</Color>
    <Color x:Key="WorkspaceColor">#FF0E121A</Color>
    <Color x:Key="SurfacePrimaryColor">#FF12161F</Color>
    <Color x:Key="SurfaceSecondaryColor">#FF161B25</Color>
    <Color x:Key="SurfaceElevatedColor">#FF1A2029</Color>
    <Color x:Key="SurfaceHoverColor">#FF202734</Color>

    <!-- ── Borders / dividers ────────────────────────────────────────────── -->
    <Color x:Key="BorderSubtleColor">#FF242B37</Color>
    <Color x:Key="BorderStrongColor">#FF323A48</Color>
    <Color x:Key="DividerColor">#FF1C222C</Color>

    <!-- ── Text ──────────────────────────────────────────────────────────── -->
    <Color x:Key="TextPrimaryColor">#FFF2F5F9</Color>
    <Color x:Key="TextSecondaryColor">#FFA8B0BF</Color>
    <Color x:Key="TextMutedColor">#FF707989</Color>

    <!-- ── Market identity ───────────────────────────────────────────────── -->
    <!-- Green/purple is mandatory and consistent across the whole product: bid
         liquidity shares the bullish-green family, ask the bearish light-purple
         family (matching the SkiaSharp ChartPalette). Bid/ask are never blue/amber. -->
    <Color x:Key="BullishColor">#FF22C55E</Color>   <!-- green -->
    <Color x:Key="BearishColor">#FFC4A7FF</Color>   <!-- light purple -->
    <Color x:Key="BidColor">#FF34D399</Color>       <!-- emerald green (bid liquidity) -->
    <Color x:Key="AskColor">#FFC4A7FF</Color>       <!-- light purple (ask liquidity) -->

    <!-- ── Status / accent ───────────────────────────────────────────────── -->
    <Color x:Key="InfoColor">#FF4FD1C5</Color>      <!-- cyan -->
    <Color x:Key="WarningColor">#FFF5B942</Color>   <!-- amber -->
    <Color x:Key="ErrorColor">#FFEF5B67</Color>     <!-- red (errors only) -->
    <Color x:Key="ReadOnlyColor">#FF8896AB</Color>  <!-- cool steel -->
    <Color x:Key="SimulatedColor">#FFF5B942</Color> <!-- gold -->
    <Color x:Key="AccentColor">#FF4FD1C5</Color>    <!-- selection accent (cyan) -->

    <!-- ════════════════════════════════════════════════════════════════════
         Brushes. Frozen by default (SolidColorBrush is freezable and WPF
         freezes resource brushes that are not referenced for animation).
         ════════════════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="WorkspaceBrush" Color="{StaticResource WorkspaceColor}" />
    <SolidColorBrush x:Key="SurfacePrimaryBrush" Color="{StaticResource SurfacePrimaryColor}" />
    <SolidColorBrush x:Key="SurfaceSecondaryBrush" Color="{StaticResource SurfaceSecondaryColor}" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />

    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />

    <SolidColorBrush x:Key="BullishBrush" Color="{StaticResource BullishColor}" />
    <SolidColorBrush x:Key="BearishBrush" Color="{StaticResource BearishColor}" />
    <SolidColorBrush x:Key="BidBrush" Color="{StaticResource BidColor}" />
    <SolidColorBrush x:Key="AskBrush" Color="{StaticResource AskColor}" />

    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="ReadOnlyBrush" Color="{StaticResource ReadOnlyColor}" />
    <SolidColorBrush x:Key="SimulatedDataBrush" Color="{StaticResource SimulatedColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

    <!-- Soft tints for status fills (badges, chips, warning bars). -->
    <SolidColorBrush x:Key="SimulatedDataSoftBrush" Color="#33F5B942" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="#26F5B942" />
    <SolidColorBrush x:Key="ErrorSoftBrush" Color="#26EF5B67" />
    <SolidColorBrush x:Key="BullishSoftBrush" Color="#2622C55E" />
    <SolidColorBrush x:Key="BearishSoftBrush" Color="#26C4A7FF" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#264FD1C5" />

    <!-- ════════════════════════════════════════════════════════════════════
         Legacy aliases. Older markup/code-behind references these keys; keep
         them mapped onto the new palette so nothing breaks.
         ════════════════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource SurfacePrimaryColor}" />
    <SolidColorBrush x:Key="GridBrush" Color="{StaticResource BorderSubtleColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource TextSecondaryColor}" />

</ResourceDictionary>
