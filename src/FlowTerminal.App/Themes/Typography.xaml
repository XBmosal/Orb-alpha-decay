<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
      Typography system. One clean Windows-native sans (Segoe UI Variable Text,
      falling back to Segoe UI). Numeric roles use tabular figures so prices and
      metrics align column-to-column. Uppercase is used only for compact labels.
    -->

    <FontFamily x:Key="UiFontFamily">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFontFamily">Cascadia Mono, Consolas, Courier New</FontFamily>

    <!-- Base text: every TextBlock inherits this unless overridden. -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <!-- Secondary / muted body. -->
    <Style x:Key="TextSecondaryStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="TextMutedStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- Application mark / title. -->
    <Style x:Key="AppTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Instrument title — prominent, easy to scan. -->
    <Style x:Key="InstrumentTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Large numeric value (last price). Tabular figures. -->
    <Style x:Key="NumericLargeStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="19" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
    </Style>

    <!-- Medium numeric value (panel hero values, e.g. CVD). -->
    <Style x:Key="NumericMediumStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
    </Style>

    <!-- Panel title (header bars). -->
    <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Small section / status label (selectively uppercase, tracked). -->
    <Style x:Key="OverlineStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Column header for tables. -->
    <Style x:Key="ColumnHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Metric value in the footer. -->
    <Style x:Key="MetricValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
    </Style>

    <!-- Diagnostics / engineering values. -->
    <Style x:Key="DiagnosticsStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- Tabular cell for tables (T&S, DOM). -->
    <Style x:Key="CellStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
