{
  "//": "Flow Terminal example configuration. Copy to appsettings.local.json (gitignored) and edit.",
  "//credentials": "NEVER put real credentials here. Use Windows Credential Manager or dotnet user-secrets.",
  "FlowTerminal": {
    "RunMode": "Mock",
    "DisplayTimeZone": "America/New_York",
    "SessionTemplate": "RegularTradingHours",
    "Instruments": ["NQ", "ES"]
  },
  "Mock": {
    "Seed": 1,
    "MeanInterEventMs": 5,
    "RealTimePacing": true
  },
  "Rithmic": {
    "Enabled": false,
    "Environment": "<provided-by-authorized-source>",
    "System": "<provided-by-authorized-source>",
    "Gateway": "<provided-by-authorized-source>",
    "CredentialSource": "WindowsCredentialManager"
  },
  "Storage": {
    "DataDirectory": "%LOCALAPPDATA%/FlowTerminal/data",
    "RetentionDays": 30,
    "MinFreeDiskGb": 5
  },
  "Serilog": {
    "MinimumLevel": "Information"
  }
}
